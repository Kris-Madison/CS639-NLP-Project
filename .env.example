# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── LLM API Keys ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Eval defaults (can also be passed as flags to run_eval.sh) ────────────────
MODEL=gpt-4o-mini
BASE_URL=https://api.openai.com/v1
TASK=os-std
JOBS=8
